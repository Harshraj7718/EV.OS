PORT=5000
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/evos?retryWrites=true&w=majority
NODE_ENV=development
CORS_ORIGIN=http://localhost:5173
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

